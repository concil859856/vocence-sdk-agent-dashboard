# ── Required ───────────────────────────────────────────────────────────
# Your Vocence developer API key (Premium plan).
# Get it at: https://www.vocence.ai/account/developer
# The DASHBOARD needs ONLY this key — the agent's brain runs hosted on Vocence.
VOCENCE_API_KEY=voc_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional ───────────────────────────────────────────────────────────
# PORT=8100
# VOCENCE_BASE_URL=https://api.vocence.ai

# ── Only for examples/byo_pipeline.py (the BYO plugins pipeline) ────────
# That path uses your own LLM as the brain (the dashboard does NOT need this).
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# VOICE=design-aria
